__pycache__/
*.pyc
.pytest_cache/
.venv/

# Local editor / env state
.vscode/

# Vendored ToolSandbox runtime artifacts
data/external/ToolSandbox/data/
data/external/ToolSandbox/.venv/

# Official ToolSandbox run outputs sometimes land under the repo-level data/ root
data/agent_*/

secrets/

.env

# Evaluation artifacts
# Default: ignore generated outputs and data, then selectively unignore
# the final paper-facing datasets and summaries we want to keep reproducible.
outputs/*
data/*

# Keep repo-curated benchmark datasets used in the paper
!data/toolsandbox.formal.json
!data/toolsandbox.formal.official.json
!data/toolsandbox.formal.train.json
!data/toolsandbox.formal.eval.json
!data/tau2_bench.formal.json
!data/tau2_bench.approval_only.json
!data/tau2_bench.binding_plus_approval_only.json

# Keep the paper-clean experiment subtree, but only selected summaries
!outputs/paper_clean_v1/
